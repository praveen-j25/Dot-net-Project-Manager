@model TaskManagerMVC.ViewModels.TeamMembersVM
@{
    ViewData["Title"] = "My Team";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">My Team</h1>
            <p class="text-muted mb-0">
                @if (!string.IsNullOrEmpty(Model.DepartmentName))
                {
                    <span>@Model.DepartmentName Department - </span>
                }
                @Model.Members.Count team member(s)
            </p>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    @if (Model.Members.Any())
    {
        <!-- Team Members Grid -->
        <div class="row g-4">
            @foreach (var member in Model.Members)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <!-- Member Header -->
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                    <i class="bi bi-person fs-4 text-primary"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mb-0">@member.FullName</h5>
                                    <small class="text-muted">@member.EmployeeId</small>
                                </div>
                                @if (member.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>

                            <!-- Member Details -->
                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-envelope text-muted me-2"></i>
                                    <small>@member.Email</small>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-briefcase text-muted me-2"></i>
                                    <small>@member.RoleName</small>
                                </div>
                                @if (!string.IsNullOrEmpty(member.TeamName))
                                {
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-people text-muted me-2"></i>
                                        <small>@member.TeamName</small>
                                    </div>
                                }
                            </div>

                            <!-- Task Statistics -->
                            <div class="border-top pt-3">
                                <div class="row text-center">
                                    <div class="col-6">
                                        <div class="mb-1">
                                            <h4 class="mb-0 text-primary">@member.ActiveTasks</h4>
                                            <small class="text-muted">Active Tasks</small>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="mb-1">
                                            <h4 class="mb-0 text-success">@member.CompletedTasks</h4>
                                            <small class="text-muted">Completed</small>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Completion Rate Progress Bar -->
                                <div class="mt-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="text-muted">Completion Rate</small>
                                        <small class="fw-bold">@member.CompletionRate.ToString("F1")%</small>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-@(member.CompletionRate >= 80 ? "success" : member.CompletionRate >= 50 ? "warning" : "danger")" 
                                             role="progressbar" 
                                             style="width: @member.CompletionRate%"
                                             aria-valuenow="@member.CompletionRate" 
                                             aria-valuemin="0" 
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="mt-3 d-flex gap-2">
                                <a href="@Url.Action("AssignTask", new { assignedTo = member.Id })" 
                                   class="btn btn-sm btn-primary flex-grow-1">
                                    <i class="bi bi-plus-circle me-1"></i>Assign Task
                                </a>
                                <a href="@Url.Action("TeamMemberDetails", new { id = member.Id })" 
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-people fs-1 text-muted d-block mb-3"></i>
                <h5 class="text-muted">No Team Members Found</h5>
                <p class="text-muted">There are no team members in your department yet.</p>
            </div>
        </div>
    }
</div>
