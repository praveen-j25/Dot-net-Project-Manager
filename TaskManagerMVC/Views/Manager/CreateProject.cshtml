@model TaskManagerMVC.ViewModels.ProjectFormVM
@{
    ViewData["Title"] = Model.Id > 0 ? "Edit Project" : "Create Project";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">@ViewData["Title"]</h1>
                    <p class="text-muted mb-0">@(Model.Id > 0 ? "Update project details" : "Create a new project")</p>
                </div>
                <a href="@Url.Action("Projects", "Admin")" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Projects
                </a>
            </div>

            <form id="projectForm" asp-action="@(Model.Id > 0 ? "EditProject" : "CreateProject")" method="post">
                <input type="hidden" asp-for="Id" />
                
                <!-- Basic Info -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0"><i class="bi bi-folder me-2 text-primary"></i>Project Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Name" class="form-label">Project Name <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="Enter project name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Code" class="form-label">Project Code</label>
                                <div class="input-group">
                                    <input asp-for="Code" class="form-control text-uppercase" placeholder="PRJ001" />
                                    @if (Model.Id == 0) {
                                        <button type="button" class="btn btn-outline-secondary" id="btnGenerateCode" title="Generate new code">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    }
                                </div>
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4" 
                                          placeholder="Describe the project objectives and scope..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Timeline & Status -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0"><i class="bi bi-calendar-range me-2 text-success"></i>Timeline & Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="StartDate" class="form-label">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EndDate" class="form-label">Target End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Status" class="form-label">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="planning">Planning</option>
                                    <option value="active">Active</option>
                                    <option value="on_hold">On Hold</option>
                                    <option value="completed">Completed</option>
                                    <option value="cancelled">Cancelled</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-4">
                                <label asp-for="Budget" class="form-label">Budget</label>
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input asp-for="Budget" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Management -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0"><i class="bi bi-person-gear me-2 text-warning"></i>Project Management</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label asp-for="ClientName" class="form-label">Client Name</label>
                                <input asp-for="ClientName" class="form-control" placeholder="Enter client name" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("MyProjects", "Manager")" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" id="submitBtn" class="btn btn-primary px-4">
                        <span class="btn-text">
                            <i class="bi bi-check-circle me-2"></i>@(Model.Id > 0 ? "Update Project" : "Create Project")
                        </span>
                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Function to generate project code
            function generateProjectCode() {
                $.ajax({
                    url: '@Url.Action("GenerateProjectCode", "Manager")',
                    type: 'GET',
                    success: function(response) {
                        if (response.projectCode) {
                            $('#Code').val(response.projectCode);
                        }
                    },
                    error: function() {
                        console.error('Failed to generate project code');
                    }
                });
            }
            
            // Auto-generate project code on page load (only for new projects)
            @if (Model.Id == 0) {
                <text>
                generateProjectCode();
                
                // Handle manual regenerate button click
                $('#btnGenerateCode').on('click', function() {
                    generateProjectCode();
                });
                </text>
            }
            
            // Convert project code to uppercase as user types
            $('#Code').on('input', function() {
                this.value = this.value.toUpperCase();
            });

            // Handle form submission with AJAX
            $('#projectForm').on('submit', function(e) {
                e.preventDefault();
                
                // Validate form
                if (!$(this).valid()) {
                    return false;
                }
                
                var $form = $(this);
                var $submitBtn = $('#submitBtn');
                var $btnText = $submitBtn.find('.btn-text');
                var $spinner = $submitBtn.find('.spinner-border');
                
                // Disable button and show spinner
                $submitBtn.prop('disabled', true);
                $btnText.addClass('d-none');
                $spinner.removeClass('d-none');
                
                $.ajax({
                    url: $form.attr('action'),
                    type: 'POST',
                    data: $form.serialize(),
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    success: function(response) {
                        // Show success toast
                        showToast('@(Model.Id > 0 ? "Project updated successfully!" : "Project created successfully!")', 'success');
                        
                        // Reset form for new projects
                        @if (Model.Id == 0) {
                            <text>
                            $form[0].reset();
                            generateProjectCode();
                            </text>
                        }
                        
                        // Re-enable button
                        $submitBtn.prop('disabled', false);
                        $btnText.removeClass('d-none');
                        $spinner.addClass('d-none');
                    },
                    error: function(xhr) {
                        // Show error toast
                        var errorMessage = 'An error occurred while saving the project.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        } else if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                if (response.message) {
                                    errorMessage = response.message;
                                }
                            } catch (e) {
                                // Use default error message
                            }
                        }
                        showToast(errorMessage, 'error');
                        
                        // Re-enable button
                        $submitBtn.prop('disabled', false);
                        $btnText.removeClass('d-none');
                        $spinner.addClass('d-none');
                    }
                });
                
                return false;
            });
        });
    </script>
}
