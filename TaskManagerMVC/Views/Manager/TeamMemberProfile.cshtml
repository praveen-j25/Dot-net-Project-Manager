@model TaskManagerMVC.ViewModels.ProfileVM
@{
    ViewData["Title"] = "Team Member Profile";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">Team Member Profile</h1>
                    <p class="text-muted mb-0">View team member information</p>
                </div>
                <a asp-action="MyTeam" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Team
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" 
                             style="width: 100px; height: 100px; font-size: 2.5rem;">
                            @Model.Initials
                        </div>
                    </div>
                    <h4 class="mb-1">@Model.FullName</h4>
                    <p class="text-muted mb-3">@Model.JobTitle</p>
                    <span class="badge bg-info">@Model.RoleName</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Contact Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Email:</div>
                        <div class="col-sm-8">@Model.Email</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Phone:</div>
                        <div class="col-sm-8">@(Model.Phone ?? "Not provided")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Department:</div>
                        <div class="col-sm-8">@Model.DepartmentName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Job Title:</div>
                        <div class="col-sm-8">@Model.JobTitle</div>
                    </div>
                    @if (Model.HireDate.HasValue)
                    {
                        <div class="row">
                            <div class="col-sm-4 fw-bold">Hire Date:</div>
                            <div class="col-sm-8">@Model.HireDate.Value.ToString("MMMM dd, yyyy")</div>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Task Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-3">
                                <h3 class="text-primary mb-1">@Model.TotalTasks</h3>
                                <small class="text-muted">Total Tasks</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <h3 class="text-success mb-1">@Model.CompletedTasks</h3>
                                <small class="text-muted">Completed</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <h3 class="text-warning mb-1">@Model.PendingTasks</h3>
                                <small class="text-muted">Pending</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
