@model TaskListVM
@{ ViewData["Title"] = "Tasks"; }

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title"><i class="bi bi-list-task me-2"></i>My Tasks</h2>
            <p class="text-muted mb-0">Manage and track all your tasks</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-2"></i>New Task
        </a>
    </div>

    <!-- Filter Card -->
    <div class="card mb-4 animate-in">
        <div class="card-body py-3">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">
                        <i class="bi bi-clipboard-check me-1"></i>Status
                    </label>
                    <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">
                        <i class="bi bi-flag me-1"></i>Priority
                    </label>
                    <select asp-for="PriorityId" asp-items="Model.Priorities" class="form-select">
                        <option value="">All Priorities</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">
                        <i class="bi bi-folder me-1"></i>Category
                    </label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">All Categories</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-funnel me-1"></i>Apply Filters
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Clear all filters">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Task Table -->
    @if (Model.Tasks?.Any() == true)
    {
        <div class="card animate-in" style="animation-delay: 0.1s;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 30%">Task</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Due Date</th>
                                <th class="text-center" style="width: 120px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.Tasks)
                            {
                                var priorityClass = task.PriorityName?.ToLower() switch
                                {
                                    "high" => "bg-high",
                                    "medium" => "bg-medium",
                                    _ => "bg-low"
                                };
                                var statusClass = task.StatusName?.ToLower().Replace(" ", "") switch
                                {
                                    "completed" => "bg-completed",
                                    "inprogress" => "bg-inprogress",
                                    "cancelled" => "bg-cancelled",
                                    _ => "bg-pending"
                                };
                                var isOverdue = task.DueDate < DateTime.Today && task.StatusName != "Completed";
                                var priorityBorder = task.PriorityName?.ToLower() switch
                                {
                                    "high" => "priority-high",
                                    "medium" => "priority-medium",
                                    _ => "priority-low"
                                };

                                <tr class="@(isOverdue ? "task-overdue" : "") @priorityBorder">
                                    <td>
                                        <a asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none fw-semibold d-block">
                                            @task.Title
                                        </a>
                                        @if (!string.IsNullOrEmpty(task.Description))
                                        {
                                            <small class="text-muted d-block text-truncate" style="max-width: 300px;">
                                                @task.Description
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <span class="text-muted">
                                            <i class="bi bi-folder me-1"></i>@(task.CategoryName ?? "Uncategorized")
                                        </span>
                                    </td>
                                    <td><span class="badge @priorityClass">@task.PriorityName</span></td>
                                    <td><span class="badge @statusClass">@task.StatusName</span></td>
                                    <td>
                                        @if (task.DueDate.HasValue)
                                        {
                                            <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                                <i class="bi bi-calendar@(isOverdue ? "-x" : "") me-1"></i>
                                                @task.DueDate.Value.ToString("MMM dd, yyyy")
                                                @if (isOverdue)
                                                {
                                                    <small class="d-block text-danger">Overdue!</small>
                                                }
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@task.Id" 
                                               class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@task.Id" 
                                               class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="Edit Task">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Delete Task">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-light">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    Showing @Model.Tasks.Count() task(s)
                </small>
            </div>
        </div>
    }
    else
    {
        <div class="card animate-in">
            <div class="card-body">
                <div class="empty-state py-5">
                    <i class="bi bi-inbox d-block"></i>
                    <h4 class="mt-3 mb-2">No tasks found</h4>
                    <p class="text-muted mb-4">Get started by creating your first task or adjust your filters</p>
                    <a asp-action="Create" class="btn btn-success btn-lg">
                        <i class="bi bi-plus-lg me-2"></i>Create Your First Task
                    </a>
                </div>
            </div>
        </div>
    }
</div>
