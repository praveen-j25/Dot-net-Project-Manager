@model TaskManagerMVC.ViewModels.TaskListVM
@{
    ViewData["Title"] = "My Tasks";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">My Tasks</h1>
            <p class="text-muted mb-0">Manage and track your assigned tasks</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Status</label>
                    <select name="statusId" class="form-select">
                        <option value="">All Statuses</option>
                        @if(Model.Statuses != null)
                        {
                            @foreach(var status in Model.Statuses)
                            {
                                <option value="@status.Value" selected="@(status.Value == Model.StatusId?.ToString())">@status.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Priority</label>
                    <select name="priorityId" class="form-select">
                        <option value="">All Priorities</option>
                        @if(Model.Priorities != null)
                        {
                            @foreach(var priority in Model.Priorities)
                            {
                                <option value="@priority.Value" selected="@(priority.Value == Model.PriorityId?.ToString())">@priority.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Sort By</label>
                    <select name="sortBy" class="form-select">
                        <option value="">Date Created</option>
                        <option value="due_date">Due Date</option>
                        <option value="priority">Priority</option>
                        <option value="status">Status</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    <a href="@Url.Action("MyTasks", "Employee")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Task Tabs -->
    <ul class="nav nav-tabs mb-4" id="taskTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" 
                    type="button" role="tab">
                All Tasks <span class="badge bg-secondary ms-1">@Model.Tasks?.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="inprogress-tab" data-bs-toggle="tab" data-bs-target="#inprogress" 
                    type="button" role="tab">
                In Progress <span class="badge bg-primary ms-1">@Model.Tasks?.Count(t => t.StatusId == 3)</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" 
                    type="button" role="tab">
                Pending <span class="badge bg-warning text-dark ms-1">@Model.Tasks?.Count(t => t.StatusId == 1 || t.StatusId == 2)</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" 
                    type="button" role="tab">
                Completed <span class="badge bg-success ms-1">@Model.Tasks?.Count(t => t.StatusId == 7)</span>
            </button>
        </li>
    </ul>

    <!-- Tasks List -->
    <div class="tab-content" id="taskTabsContent">
        <div class="tab-pane fade show active" id="all" role="tabpanel">
            @await Html.PartialAsync("_TasksTable", Model.Tasks)
        </div>
        <div class="tab-pane fade" id="inprogress" role="tabpanel">
            @await Html.PartialAsync("_TasksTable", Model.Tasks?.Where(t => t.StatusId == 3).ToList())
        </div>
        <div class="tab-pane fade" id="pending" role="tabpanel">
            @await Html.PartialAsync("_TasksTable", Model.Tasks?.Where(t => t.StatusId == 1 || t.StatusId == 2).ToList())
        </div>
        <div class="tab-pane fade" id="completed" role="tabpanel">
            @await Html.PartialAsync("_TasksTable", Model.Tasks?.Where(t => t.StatusId == 7).ToList())
        </div>
    </div>
</div>

<!-- Update Status Modal -->
@section Modals {
<div class="modal fade" id="updateStatusModal" tabindex="-1" aria-hidden="true" style="z-index: 1055;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="UpdateTaskStatus" asp-controller="Employee" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="taskId" id="modalTaskId" value="" />
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-arrow-repeat me-2"></i>Update Task Status
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">New Status</label>
                        <select name="statusId" class="form-select" required>
                            <option value="">-- Select Status --</option>
                            <option value="1">Pending</option>
                            <option value="2">Assigned</option>
                            <option value="3">In Progress</option>
                            <option value="4">In Review</option>
                            <option value="5">Testing</option>
                            <option value="6">Blocked</option>
                            <option value="7">Completed</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Update Status
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var modalEl = document.getElementById('updateStatusModal');
        if (modalEl) {
            var modal = new bootstrap.Modal(modalEl);
            
            // Handle modal show event
            modalEl.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                if (button) {
                    var taskId = button.getAttribute('data-task-id');
                    document.getElementById('modalTaskId').value = taskId;
                }
            });
        }
    });
</script>
}

