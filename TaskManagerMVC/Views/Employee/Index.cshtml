@model TaskManagerMVC.ViewModels.EmployeeDashboardVM
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container-fluid px-4 py-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1" style="color:#0f172a;">
                        Good @(DateTime.Now.Hour < 12 ? "Morning" : DateTime.Now.Hour < 17 ? "Afternoon" : "Evening"), @Model.EmployeeName
                    </h2>
                    <p class="text-muted mb-0">
                        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                        @if(!string.IsNullOrEmpty(Model.JobTitle))
                        {
                            <span class="mx-2">|</span>
                            <i class="bi bi-briefcase me-1"></i>@Model.JobTitle
                        }
                        @if(!string.IsNullOrEmpty(Model.DepartmentName))
                        {
                            <span class="mx-2">|</span>
                            <i class="bi bi-building me-1"></i>@Model.DepartmentName
                        }
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a href="@Url.Action("MyTasks", "Employee")" class="btn btn-primary">
                        <i class="bi bi-list-task me-1"></i>My Tasks
                    </a>
                    <a href="@Url.Action("Notifications", "Employee")" class="btn btn-outline-primary position-relative">
                        <i class="bi bi-bell me-1"></i>Notifications
                        @if(Model.UnreadNotifications > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@Model.UnreadNotifications</span>
                        }
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card primary" style="border-radius:16px; padding:1.25rem;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75">Total Tasks</p>
                        <h2 class="mb-0 fw-bold">@Model.TotalTasks</h2>
                    </div>
                    <div class="bg-white bg-opacity-25 rounded-3 p-2">
                        <i class="bi bi-list-task fs-5"></i>
                    </div>
                </div>
                <div class="mt-2"><small class="opacity-75">All assigned to you</small></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card info" style="border-radius:16px; padding:1.25rem;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75">In Progress</p>
                        <h2 class="mb-0 fw-bold">@Model.InProgressTasks</h2>
                    </div>
                    <div class="bg-white bg-opacity-25 rounded-3 p-2">
                        <i class="bi bi-arrow-repeat fs-5"></i>
                    </div>
                </div>
                <div class="mt-2"><small class="opacity-75">Currently working on</small></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card success" style="border-radius:16px; padding:1.25rem;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75">Completed</p>
                        <h2 class="mb-0 fw-bold">@Model.CompletedTasks</h2>
                    </div>
                    <div class="bg-white bg-opacity-25 rounded-3 p-2">
                        <i class="bi bi-check-circle fs-5"></i>
                    </div>
                </div>
                <div class="mt-2"><small class="opacity-75">@Model.CompletionRate% completion rate</small></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card danger" style="border-radius:16px; padding:1.25rem;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75">Overdue</p>
                        <h2 class="mb-0 fw-bold">@Model.MyOverdueTasks</h2>
                    </div>
                    <div class="bg-white bg-opacity-25 rounded-3 p-2">
                        <i class="bi bi-exclamation-triangle fs-5"></i>
                    </div>
                </div>
                <div class="mt-2"><small class="opacity-75">Needs attention</small></div>
            </div>
        </div>
    </div>

    <!-- Time Stats Bar -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:linear-gradient(135deg,#7c3aed,#a78bfa);">
                        <i class="bi bi-clock-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@Model.MyHoursThisWeek.ToString("F1")h</h5>
                        <small class="text-muted">Hours this week</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:linear-gradient(135deg,#2563eb,#60a5fa);">
                        <i class="bi bi-calendar-month-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@Model.MyHoursThisMonth.ToString("F1")h</h5>
                        <small class="text-muted">Hours this month</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:linear-gradient(135deg,#059669,#34d399);">
                        <i class="bi bi-graph-up-arrow text-white fs-5"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@Model.CompletionRate%</h5>
                        <small class="text-muted">Completion rate</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Today's Tasks -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                <div class="card-header bg-white border-0 py-3 px-4" style="border-radius:14px 14px 0 0;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-check text-primary me-2"></i>Today's Tasks</h5>
                        <a href="@Url.Action("MyTasks", "Employee")" class="btn btn-sm btn-outline-primary rounded-pill px-3">View All</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if(Model.TodayTasks?.Any() == true)
                    {
                        <div class="list-group list-group-flush">
                            @foreach(var task in Model.TodayTasks)
                            {
                                var pColor = task.PriorityName?.ToLower() switch { "critical" => "#ef4444", "high" => "#f59e0b", "medium" => "#3b82f6", _ => "#94a3b8" };
                                <a href="@Url.Action("TaskDetails", "Employee", new { id = task.Id })" class="list-group-item list-group-item-action border-0 py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width:4px; height:40px; border-radius:2px; background:@pColor;"></div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 fw-semibold">@task.Title</h6>
                                            <small class="text-muted">Due: @(task.DueDate?.ToString("h:mm tt") ?? "Today")</small>
                                        </div>
                                        <span class="badge rounded-pill" style="background:@(pColor)20; color:@pColor; font-weight:600;">@task.PriorityName</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-3" style="width:60px;height:60px;background:#f1f5f9;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;">
                                <i class="bi bi-calendar-check fs-4 text-muted"></i>
                            </div>
                            <p class="text-muted mb-1 fw-medium">No tasks for today</p>
                            <small class="text-muted">You're all caught up!</small>
                        </div>
                    }
                </div>
            </div>

            <!-- Upcoming Tasks -->
            @if(Model.UpcomingTasks?.Any() == true)
            {
                <div class="card border-0 shadow-sm mt-4" style="border-radius:14px;">
                    <div class="card-header bg-white border-0 py-3 px-4" style="border-radius:14px 14px 0 0;">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-clock text-info me-2"></i>Upcoming (Next 7 Days)</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach(var task in Model.UpcomingTasks)
                            {
                                var pColor = task.PriorityName?.ToLower() switch { "critical" => "#ef4444", "high" => "#f59e0b", "medium" => "#3b82f6", _ => "#94a3b8" };
                                <a href="@Url.Action("TaskDetails", "Employee", new { id = task.Id })" class="list-group-item list-group-item-action border-0 py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width:4px; height:40px; border-radius:2px; background:@pColor;"></div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 fw-semibold">@task.Title</h6>
                                            <small class="text-muted">Due: @(task.DueDate?.ToString("MMM dd, yyyy") ?? "-")</small>
                                        </div>
                                        <span class="badge rounded-pill" style="background:@(pColor)20; color:@pColor; font-weight:600;">@task.PriorityName</span>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right Sidebar -->
        <div class="col-lg-4">
            <!-- Performance Ring -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
                <div class="card-body text-center py-4">
                    <h6 class="text-muted fw-bold mb-3">Task Completion</h6>
                    <div class="position-relative d-inline-block mb-3" style="width: 130px; height: 130px;">
                        <svg viewBox="0 0 36 36" style="width:100%;height:100%;transform:rotate(-90deg);">
                            <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                  fill="none" stroke="#e2e8f0" stroke-width="2.5"/>
                            <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                  fill="none" stroke="url(#gradient)" stroke-width="2.5" stroke-linecap="round"
                                  stroke-dasharray="@Model.CompletionRate, 100"/>
                            <defs>
                                <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#7c3aed"/>
                                    <stop offset="100%" stop-color="#2563eb"/>
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="position-absolute top-50 start-50 translate-middle">
                            <h3 class="mb-0 fw-bold" style="color:#7c3aed;">@Model.CompletionRate%</h3>
                        </div>
                    </div>
                    <p class="text-muted small mb-0">@Model.CompletedTasks of @Model.TotalTasks tasks done</p>
                </div>
            </div>

            <!-- Overdue Alert -->
            @if(Model.OverdueTasks?.Count > 0)
            {
                <div class="card border-0 shadow-sm mb-4" style="border-radius:14px; border-left: 4px solid #ef4444 !important;">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-start gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#fef2f2;">
                                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-danger">@Model.OverdueTasks.Count Overdue</h6>
                                <p class="mb-2 small text-muted">Tasks need immediate attention</p>
                                <a href="@Url.Action("MyTasks", "Employee", new { filter = "overdue" })" class="btn btn-sm btn-danger rounded-pill px-3">
                                    <i class="bi bi-arrow-right me-1"></i>View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Quick Actions -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
                <div class="card-header bg-white border-0 py-3 px-4" style="border-radius:14px 14px 0 0;">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h6>
                </div>
                <div class="card-body pt-0">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("MyTasks", "Employee")" class="btn btn-outline-primary btn-sm text-start rounded-pill px-3">
                            <i class="bi bi-list-task me-2"></i>All My Tasks
                        </a>
                        <a href="@Url.Action("MyTimeLogs", "Employee")" class="btn btn-outline-success btn-sm text-start rounded-pill px-3">
                            <i class="bi bi-clock-history me-2"></i>My Time Logs
                        </a>
                        <a href="@Url.Action("Notifications", "Employee")" class="btn btn-outline-info btn-sm text-start rounded-pill px-3">
                            <i class="bi bi-bell me-2"></i>Notifications
                        </a>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            @if(Model.RecentActivity?.Any() == true)
            {
                <div class="card border-0 shadow-sm" style="border-radius:14px;">
                    <div class="card-header bg-white border-0 py-3 px-4" style="border-radius:14px 14px 0 0;">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-activity text-success me-2"></i>Recent Activity</h6>
                    </div>
                    <div class="card-body pt-0 px-4">
                        @foreach(var activity in Model.RecentActivity.Take(5))
                        {
                            <div class="d-flex gap-2 py-2 border-bottom" style="border-color:#f1f5f9 !important;">
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                                    <i class="bi bi-activity text-muted small"></i>
                                </div>
                                <div>
                                    <p class="mb-0 small">@activity.Action</p>
                                    <small class="text-muted">@activity.CreatedAt.ToString("MMM dd, h:mm tt")</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
