@model TaskManagerMVC.ViewModels.SettingsVM

@{
    ViewData["Title"] = "Account Settings";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Account Settings</h1>
            <p class="text-muted small">Manage your account security and preferences.</p>
        </div>
    </div>

    <div class="row">
        <!-- Settings Nav -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="list-group list-group-flush rounded-3">
                    <a href="#" class="list-group-item list-group-item-action active py-3">
                        <i class="bi bi-shield-lock me-2"></i> Security
                        <small class="d-block text-white-50 mt-1">Change your password</small>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3 disabled">
                        <i class="bi bi-bell me-2"></i> Notifications
                        <small class="d-block text-muted mt-1">Manage email alerts (Coming Soon)</small>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3 disabled">
                        <i class="bi bi-display me-2"></i> Appearance
                        <small class="d-block text-muted mt-1">Theme customization (Coming Soon)</small>
                    </a>
                </div>
            </div>
        </div>

        <!-- Password Form -->
        <div class="col-xl-8 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Change Password</h6>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Settings" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label font-weight-bold">Current Password</label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" required />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label font-weight-bold">New Password</label>
                            <input asp-for="NewPassword" class="form-control" type="password" required />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            <div class="form-text">Password must be at least 6 characters long.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label font-weight-bold">Confirm New Password</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" type="password" required />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="reset" class="btn btn-light border me-2">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-2"></i> Update Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
