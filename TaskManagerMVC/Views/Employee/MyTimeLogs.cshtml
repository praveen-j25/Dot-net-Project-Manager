@model List<TaskManagerMVC.ViewModels.TimeLogVM>
@{
    ViewData["Title"] = "My Time Logs";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">My Time Logs</h1>
            <p class="text-muted mb-0">Track your logged hours</p>
        </div>
        <a href="@Url.Action("Index", "Employee")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Dashboard
        </a>
    </div>

    <!-- Date Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end" id="dateFilterForm">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Start Date</label>
                    <input type="date" name="startDate" id="startDate" class="form-control" value="@(((DateTime?)ViewBag.StartDate)?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">End Date</label>
                    <input type="date" name="endDate" id="endDate" class="form-control" value="@(((DateTime?)ViewBag.EndDate)?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-2"></i>Filter
                    </button>
                </div>
            </form>
            <div id="dateError" class="text-danger mt-2" style="display: none;">
                <i class="bi bi-exclamation-circle me-1"></i>
                <span>End Date must be after Start Date</span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h3 mb-1 text-primary">@Model.Sum(l => l.HoursLogged).ToString("N1")h</div>
                <small class="text-muted">Total Hours</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h3 mb-1 text-success">@Model.Where(l => l.IsBillable).Sum(l => l.HoursLogged).ToString("N1")h</div>
                <small class="text-muted">Billable Hours</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h3 mb-1 text-warning">₹@((Model.Where(l => l.IsBillable).Sum(l => l.HoursLogged) * 500).ToString("N0"))</div>
                <small class="text-muted">Billable Amount (est.)</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h3 mb-1 text-info">@Model.Count</div>
                <small class="text-muted">Entries</small>
            </div>
        </div>
    </div>

    <!-- Time Logs Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Hours</th>
                                <th>Description</th>
                                <th>Billable</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td>@log.LogDate.ToString("MMM d, yyyy")</td>
                                    <td><strong>@log.HoursLogged.ToString("N1")h</strong></td>
                                    <td class="text-muted">@(log.Description ?? "-")</td>
                                    <td>
                                        @if (log.IsBillable)
                                        {
                                            <div>
                                                <span class="badge bg-success-subtle text-success-emphasis mb-1">Billable</span>
                                                <div class="small fw-bold text-success">₹@((log.HoursLogged * 500).ToString("N0"))</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary-emphasis">Non-billable</span>
                                        }
                                    </td>
                                    <td>
                                        @if (log.IsApproved)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis">Pending</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-clock-history fs-1"></i>
                    <p class="mt-2">No time logs found for this period</p>
                </div>
            }
        </div>
    </div>
</div>


@section Scripts {
<script>
    document.getElementById('dateFilterForm').addEventListener('submit', function(e) {
        const startDate = document.getElementById('startDate').value;
        const endDate = document.getElementById('endDate').value;
        const errorDiv = document.getElementById('dateError');
        
        if (startDate && endDate) {
            const start = new Date(startDate);
            const end = new Date(endDate);
            
            if (start > end) {
                e.preventDefault();
                errorDiv.style.display = 'block';
                document.getElementById('endDate').classList.add('is-invalid');
                return false;
            }
        }
        
        errorDiv.style.display = 'none';
        document.getElementById('endDate').classList.remove('is-invalid');
    });
    
    document.getElementById('startDate').addEventListener('change', function() {
        document.getElementById('dateError').style.display = 'none';
        document.getElementById('endDate').classList.remove('is-invalid');
    });
    
    document.getElementById('endDate').addEventListener('change', function() {
        document.getElementById('dateError').style.display = 'none';
        this.classList.remove('is-invalid');
    });
</script>
}
