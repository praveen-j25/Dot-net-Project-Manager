@model TaskManagerMVC.ViewModels.TaskListVM
@{
    ViewData["Title"] = "Task Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Task Management</h1>
            <p class="text-muted mb-0">Manage and assign tasks to team members</p>
        </div>
        <a href="@Url.Action("AssignTask", "Admin")" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Assign New Task
        </a>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Status</label>
                    <select name="statusId" class="form-select">
                        <option value="">All Statuses</option>
                        @if(Model.Statuses != null)
                        {
                            @foreach(var status in Model.Statuses)
                            {
                                <option value="@status.Value" selected="@(status.Value == Model.StatusId?.ToString())">@status.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Priority</label>
                    <select name="priorityId" class="form-select">
                        <option value="">All Priorities</option>
                        @if(Model.Priorities != null)
                        {
                            @foreach(var priority in Model.Priorities)
                            {
                                <option value="@priority.Value" selected="@(priority.Value == Model.PriorityId?.ToString())">@priority.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Project</label>
                    <select name="projectId" class="form-select">
                        <option value="">All Projects</option>
                        @if(ViewBag.Projects != null)
                        {
                            var projects = ViewBag.Projects as IEnumerable<SelectListItem>;
                            if (projects != null)
                            {
                                @foreach(var proj in projects)
                                {
                                    <option value="@proj.Value" selected="@(proj.Value == Model.ProjectId?.ToString())">@proj.Text</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    <a href="@Url.Action("AssignTasks", "Admin")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tasks Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Task</th>
                            <th>Assignee</th>
                            <th>Project</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model.Tasks?.Any() == true)
                        {
                            @foreach(var task in Model.Tasks)
                            {
                                var priorityBadge = task.PriorityName?.ToLower() switch
                                {
                                    "critical" => "bg-danger",
                                    "high" => "bg-warning text-dark",
                                    "medium" => "bg-info",
                                    _ => "bg-secondary"
                                };
                                
                                var statusBadge = task.StatusName?.ToLower() switch
                                {
                                    "completed" => "bg-success",
                                    "in progress" => "bg-primary",
                                    "in review" => "bg-warning text-dark",
                                    "on hold" => "bg-secondary",
                                    _ => "bg-info"
                                };

                                var isOverdue = task.DueDate.HasValue && task.DueDate < DateTime.Today 
                                    && task.StatusName?.ToLower() != "completed";

                                <tr>
                                    <td class="ps-4">
                                        <div>
                                            <a href="@Url.Action("TaskDetails", "Admin", new { id = task.Id })" 
                                               class="text-decoration-none fw-medium">
                                                @task.Title
                                            </a>
                                            @if(!string.IsNullOrEmpty(task.CategoryName))
                                            {
                                                <br><small class="text-muted">@task.CategoryName</small>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @if(!string.IsNullOrEmpty(task.AssigneeName))
                                        {
                                            <span>@task.AssigneeName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Unassigned</span>
                                        }
                                    </td>
                                    <td>
                                        @if(!string.IsNullOrEmpty(task.ProjectName))
                                        {
                                            <span class="badge bg-light text-dark">@task.ProjectName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td><span class="badge @priorityBadge">@task.PriorityName</span></td>
                                    <td><span class="badge @statusBadge">@task.StatusName</span></td>
                                    <td>
                                        @if(task.DueDate.HasValue)
                                        {
                                            <span class="@(isOverdue ? "text-danger fw-medium" : "")">
                                                @task.DueDate.Value.ToString("MMM dd, yyyy")
                                                @if(isOverdue)
                                                {
                                                    <i class="bi bi-exclamation-circle ms-1"></i>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a href="@Url.Action("TaskDetails", "Admin", new { id = task.Id })" 
                                               class="btn btn-sm btn-outline-secondary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="@Url.Action("EditAssignment", "Admin", new { id = task.Id })" 
                                               class="btn btn-sm btn-outline-primary" title="Edit Task">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                                    title="Delete Task"
                                                    data-task-id="@task.Id"
                                                    data-task-title="@task.Title"
                                                    onclick="confirmDelete(this.getAttribute('data-task-id'), this.getAttribute('data-task-title'))">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                        <p class="mb-2">No tasks found</p>
                                        <a href="@Url.Action("AssignTask", "Admin")" class="btn btn-sm btn-primary">
                                            Assign First Task
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
@section Modals {
<div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-hidden="true" style="z-index: 1055;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Task
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-flex align-items-center mb-3">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0 me-2"></i>
                    <div>
                        <strong>Warning:</strong> This action <strong>cannot</strong> be undone.
                    </div>
                </div>
                
                <p class="mb-2">You are about to delete the following task:</p>

                <div class="card bg-light border-0 mb-3">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Task:</span>
                            <strong id="deleteTaskName" class="text-dark"></strong>
                        </div>
                    </div>
                </div>

                <p class="small text-muted mb-0">
                    All associated comments and time logs will also be deleted.
                </p>

                <form id="deleteTaskForm" method="post" asp-action="DeleteTask" class="mt-4">
                    <input type="hidden" id="deleteTaskId" name="id" />
                    
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Delete Task
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const modalEl = document.getElementById('deleteTaskModal');
        if (modalEl) {
            const modal = new bootstrap.Modal(modalEl);

            window.confirmDelete = function(taskId, taskTitle) {
                document.getElementById('deleteTaskId').value = taskId;
                document.getElementById('deleteTaskName').textContent = taskTitle;
                
                modal.show();
            };
        }
    });
</script>
}

