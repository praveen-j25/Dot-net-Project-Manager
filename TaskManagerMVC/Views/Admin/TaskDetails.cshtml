@model TaskManagerMVC.ViewModels.TaskDetailsEnhancedVM
@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">@Model.Title</h1>
            <p class="text-muted mb-0">
                <span class="badge bg-@(Model.TaskType == "bug" ? "danger" : Model.TaskType == "feature" ? "success" : "primary") me-2">@Model.TaskType</span>
                Created @Model.CreatedAt.ToString("MMM d, yyyy")
            </p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("EditAssignment", "Admin", new { id = Model.Id })" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-2"></i>Edit
            </a>
            <a href="@Url.Action("AssignTasks", "Admin")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Description -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-3">Description</h6>
                    <p class="mb-0">@(Model.Description ?? "No description provided.")</p>
                </div>
            </div>

            <!-- Progress -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <h6 class="mb-0">Progress</h6>
                        <strong>@Model.Progress%</strong>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-primary" style="width: @Model.Progress%"></div>
                    </div>
                </div>
            </div>

            <!-- Attachments -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
                    <h6 class="text-muted text-uppercase small mb-0"><i class="bi bi-paperclip me-2"></i>Attachments (@Model.Attachments.Count)</h6>
                </div>
                <div class="card-body pt-0">
                    @if (Model.Attachments.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var file in Model.Attachments)
                            {
                                var icon = "bi-file-earmark";
                                if (!string.IsNullOrEmpty(file.FileType))
                                {
                                    icon = file.FileType.ToLower() switch
                                    {
                                        "pdf" => "bi-file-earmark-pdf",
                                        "doc" or "docx" => "bi-file-earmark-word",
                                        "xls" or "xlsx" or "csv" => "bi-file-earmark-excel",
                                        "ppt" or "pptx" => "bi-file-earmark-slides",
                                        "jpg" or "jpeg" or "png" or "gif" => "bi-file-earmark-image",
                                        "zip" or "rar" => "bi-file-earmark-zip",
                                        "txt" => "bi-file-earmark-text",
                                        _ => "bi-file-earmark"
                                    };
                                }

                                <div class="list-group-item px-0 d-flex align-items-center gap-3 border-bottom-0 pb-3">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center bg-light" style="width:40px;height:40px;">
                                        <i class="bi @icon fs-5 text-secondary"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <a href="/File/Attachment/@file.Id" target="_blank" class="text-decoration-none text-dark fw-medium text-truncate d-block">@file.OriginalName</a>
                                        <small class="text-muted">
                                            @file.FileSize &bull; @file.CreatedAt.ToString("MMM d") &bull; @file.UploaderName
                                        </small>
                                    </div>
                                    <div>
                                        <a href="/File/Attachment/@file.Id" download class="btn btn-sm btn-outline-secondary rounded-circle" data-bs-toggle="tooltip" title="Download">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No attachments found.</p>
                    }
                </div>
            </div>

            <!-- Time Tracking -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-3">Time Tracking</h6>
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="h4 mb-1">@Model.EstimatedHours.ToString("N1")h</div>
                            <small class="text-muted">Estimated</small>
                        </div>
                        <div class="col-4">
                            <div class="h4 mb-1">@Model.ActualHours.ToString("N1")h</div>
                            <small class="text-muted">Actual</small>
                        </div>
                        <div class="col-4">
                            <div class="h4 mb-1 @(Model.EstimatedHours > 0 && Model.ActualHours > Model.EstimatedHours ? "text-danger" : "text-success")">
                                @((Model.EstimatedHours - Model.ActualHours).ToString("N1"))h
                            </div>
                            <small class="text-muted">Remaining</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments -->
            @if (Model.Comments.Any())
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Comments (@Model.Comments.Count)</h6>
                    </div>
                    <div class="card-body">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="d-flex mb-3 @(comment != Model.Comments.Last() ? "border-bottom pb-3" : "")">
                                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3" style="width:36px;height:36px;min-width:36px;">
                                    <i class="bi bi-person-fill small"></i>
                                </div>
                                <div>
                                    <div class="d-flex align-items-center gap-2">
                                        <strong class="small">@comment.UserName</strong>
                                        <span class="text-muted small">@comment.CreatedAt.ToString("MMM d, yyyy h:mm tt")</span>
                                        @if (comment.IsInternal)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis">Internal</span>
                                        }
                                    </div>
                                    <p class="mb-0 small mt-1">@comment.Comment</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-3">Details</h6>
                    <div class="mb-3">
                        <small class="text-muted d-block">Status</small>
                        <span class="badge bg-info">@Model.StatusName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Priority</small>
                        <span class="badge bg-warning">@Model.PriorityName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Category</small>
                        <strong>@(Model.CategoryName ?? "N/A")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Project</small>
                        @if (Model.ProjectId.HasValue)
                        {
                            <a href="@Url.Action("ProjectDetails", "Admin", new { id = Model.ProjectId })">@Model.ProjectName</a>
                        }
                        else
                        {
                            <strong>N/A</strong>
                        }
                    </div>
                    <hr />
                    <div class="mb-3">
                        <small class="text-muted d-block">Assigned To</small>
                        <strong>@(Model.AssigneeName ?? "Unassigned")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Assigned By</small>
                        <strong>@(Model.AssignedByName ?? "N/A")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Assigned At</small>
                        <strong>@(Model.AssignedAt?.ToString("MMM d, yyyy") ?? "N/A")</strong>
                    </div>
                    <hr />
                    <div class="mb-3">
                        <small class="text-muted d-block">Start Date</small>
                        <strong>@(Model.StartDate?.ToString("MMM d, yyyy") ?? "Not set")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Due Date</small>
                        <strong>@(Model.DueDate?.ToString("MMM d, yyyy") ?? "Not set")</strong>
                    </div>
                    @if (Model.CompletedDate.HasValue)
                    {
                        <div class="mb-3">
                            <small class="text-muted d-block">Completed</small>
                            <strong class="text-success">@Model.CompletedDate.Value.ToString("MMM d, yyyy")</strong>
                        </div>
                    }
                    <hr />
                    <div class="mb-3">
                        <small class="text-muted d-block">Billable</small>
                        <strong>@(Model.IsBillable ? "Yes" : "No")</strong>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="mb-3">
                            <small class="text-muted d-block mb-1">Tags</small>
                            @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.TrimEntries))
                            {
                                <span class="badge bg-light text-dark border me-1">@tag</span>
                            }
                        </div>
                    }
                    <hr />
                    <div>
                        <small class="text-muted d-block">Created By</small>
                        <strong>@(Model.CreatorName ?? "N/A")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
