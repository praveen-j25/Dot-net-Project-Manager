@model TaskManagerMVC.ViewModels.ApproveUserVM
@{
    ViewData["Title"] = "Approve Registration";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">
                        <i class="bi bi-person-check me-2 text-success"></i>Approve Registration
                    </h1>
                    <p class="text-muted mb-0">Review and approve user registration request</p>
                </div>
                <a href="@Url.Action("PendingRegistrations", "Admin")" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Back
                </a>
            </div>

            <form asp-action="ApproveRegistration" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FirstName" />
                <input type="hidden" asp-for="LastName" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Phone" />
                <input type="hidden" asp-for="JobTitle" />
                <input type="hidden" asp-for="DepartmentId" />
                
                <!-- Applicant Info (Read-only) -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light py-3">
                        <h5 class="mb-0"><i class="bi bi-person me-2 text-primary"></i>Applicant Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">First Name</label>
                                <p class="fw-medium">@Model.FirstName</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Last Name</label>
                                <p class="fw-medium">@Model.LastName</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Email</label>
                                <p class="fw-medium">@Model.Email</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Phone</label>
                                <p class="fw-medium">@(Model.Phone ?? "-")</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Requested Job Title</label>
                                <p class="fw-medium">@(Model.JobTitle ?? "-")</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Requested Department</label>
                                <p class="fw-medium">@(Model.DepartmentId.HasValue ? "Selected" : "-")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Assignment Details (Admin fills) -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-success bg-opacity-10 py-3">
                        <h5 class="mb-0 text-success"><i class="bi bi-check-circle me-2"></i>Assign Role & Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Please assign a role and complete the employee details below.
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="RoleId" class="form-label">Assign Role <span class="text-danger">*</span></label>
                                <select asp-for="RoleId" asp-items="Model.Roles" class="form-select">
                                    <option value="">-- Select Role --</option>
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EmployeeId" class="form-label">Employee ID</label>
                                <div class="input-group">
                                    <input asp-for="EmployeeId" class="form-control" placeholder="Will be auto-generated" readonly id="employeeIdInput" />
                                    <button type="button" class="btn btn-outline-secondary" onclick="generateEmployeeId()" title="Generate ID">
                                        <i class="bi bi-arrow-clockwise"></i> Generate
                                    </button>
                                </div>
                                <small class="text-muted">Click Generate to preview the Employee ID</small>
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label asp-for="AssignedDepartmentId" class="form-label">Department</label>
                                <select asp-for="AssignedDepartmentId" asp-items="Model.Departments" class="form-select">
                                    <option value="">-- Select Department --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TeamId" class="form-label">Team</label>
                                <select asp-for="TeamId" asp-items="Model.Teams" class="form-select">
                                    <option value="">-- Select Team --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label asp-for="ReportsTo" class="form-label">Reports To</label>
                                <select asp-for="ReportsTo" asp-items="Model.Managers" class="form-select">
                                    <option value="">-- Select Manager --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HireDate" class="form-label">Hire Date</label>
                                <input asp-for="HireDate" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("PendingRegistrations", "Admin")" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle me-2"></i>Approve & Create Account
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        async function generateEmployeeId() {
            try {
                const response = await fetch('/Admin/GenerateEmployeeId');
                const data = await response.json();
                
                if (data.employeeId) {
                    document.getElementById('employeeIdInput').value = data.employeeId;
                    document.getElementById('employeeIdInput').readOnly = false;
                }
            } catch (error) {
                console.error('Error generating Employee ID:', error);
                alert('Failed to generate Employee ID');
            }
        }
        
        // Auto-generate on page load
        window.addEventListener('DOMContentLoaded', function() {
            generateEmployeeId();
        });
    </script>
}
