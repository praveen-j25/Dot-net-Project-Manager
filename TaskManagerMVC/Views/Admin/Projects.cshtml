@model TaskManagerMVC.ViewModels.ProjectListVM
@{
    ViewData["Title"] = "Project Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Project Management</h1>
            <p class="text-muted mb-0">Manage projects and track progress</p>
        </div>
        <a href="@Url.Action("CreateProject", "Admin")" class="btn btn-primary">
            <i class="bi bi-folder-plus me-2"></i>New Project
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-primary">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Total Projects</p>
                            <h4 class="mb-0">@Model.Projects.Count</h4>
                        </div>
                        <i class="bi bi-folder text-primary fs-3 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-success">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Active</p>
                            <h4 class="mb-0">@Model.Projects.Count(p => p.Status == "active")</h4>
                        </div>
                        <i class="bi bi-check-circle text-success fs-3 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-warning">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">On Hold</p>
                            <h4 class="mb-0">@Model.Projects.Count(p => p.Status == "on_hold")</h4>
                        </div>
                        <i class="bi bi-pause-circle text-warning fs-3 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-secondary">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Completed</p>
                            <h4 class="mb-0">@Model.Projects.Count(p => p.Status == "completed")</h4>
                        </div>
                        <i class="bi bi-trophy text-secondary fs-3 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Grid -->
    <div class="row g-4">
        @if(Model.Projects?.Any() == true)
        {
            @foreach(var project in Model.Projects)
            {
                var statusBadge = project.Status switch
                {
                    "active" => "bg-success",
                    "on_hold" => "bg-warning text-dark",
                    "completed" => "bg-secondary",
                    "cancelled" => "bg-danger",
                    _ => "bg-info"
                };
                
                var statusText = project.Status switch
                {
                    "active" => "Active",
                    "on_hold" => "On Hold",
                    "completed" => "Completed",
                    "cancelled" => "Cancelled",
                    _ => "Planning"
                };

                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-light text-dark mb-2">@project.Code</span>
                                    <h5 class="card-title mb-1">
                                        <a href="@Url.Action("ProjectDetails", "Admin", new { id = project.Id })" 
                                           class="text-decoration-none text-dark">
                                            @project.Name
                                        </a>
                                    </h5>
                                </div>
                                <span class="badge @statusBadge">@statusText</span>
                            </div>

                            @if(!string.IsNullOrEmpty(project.Description))
                            {
                                <p class="text-muted small mb-3">
                                    @(project.Description.Length > 100 ? project.Description.Substring(0, 100) + "..." : project.Description)
                                </p>
                            }

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>
                                    @(project.StartDate?.ToString("MMM dd") ?? "TBD") - @(project.EndDate?.ToString("MMM dd, yyyy") ?? "Ongoing")
                                </small>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Progress</small>
                                    <small class="fw-medium">@project.Progress%</small>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar" role="progressbar" style="width: @project.Progress%"></div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-list-task me-1 text-muted"></i>
                                    <small class="text-muted">@project.TotalTasks tasks</small>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-people me-1 text-muted"></i>
                                    <small class="text-muted">@project.TeamSize members</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="btn-group w-100">
                                <a href="@Url.Action("ProjectDetails", "Admin", new { id = project.Id })" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <a href="@Url.Action("EditProject", "Admin", new { id = project.Id })" 
                                   class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <button type="button" 
                                        class="btn btn-outline-danger btn-sm" 
                                        onclick="showDeleteModal(@project.Id, '@project.Name', '@project.Code')">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-folder2-open fs-1 text-muted mb-3 d-block"></i>
                        <p class="text-muted mb-3">No projects found</p>
                        <a href="@Url.Action("CreateProject", "Admin")" class="btn btn-primary">
                            <i class="bi bi-folder-plus me-2"></i>Create First Project
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Modals {
<!-- Delete Project Modal -->
<div class="modal fade" id="deleteProjectModal" tabindex="-1" aria-hidden="true" style="z-index: 1055;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Project
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-flex align-items-center mb-3">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0 me-2"></i>
                    <div>
                        <strong>Warning:</strong> This action <strong>cannot</strong> be undone.
                    </div>
                </div>
                
                <p class="mb-2">You are about to delete the following project:</p>

                <div class="card bg-light border-0 mb-3">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Project:</span>
                            <strong id="deleteProjectName" class="text-dark"></strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Code:</span>
                            <strong id="deleteProjectCode" class="text-dark"></strong>
                        </div>
                    </div>
                </div>

                <p class="small text-muted mb-0">
                    All tasks associated with this project will be unassigned.
                </p>

                <form id="deleteProjectForm" method="post" asp-action="DeleteProject" class="mt-4">
                    <input type="hidden" id="deleteProjectId" name="id" />
                    
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Delete Project
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const modalEl = document.getElementById('deleteProjectModal');
        if (modalEl) {
            const modal = new bootstrap.Modal(modalEl);

            window.showDeleteModal = function(id, name, code) {
                document.getElementById('deleteProjectId').value = id;
                document.getElementById('deleteProjectName').textContent = name;
                document.getElementById('deleteProjectCode').textContent = code || 'N/A';
                
                modal.show();
            };
        }
    });
</script>
}
