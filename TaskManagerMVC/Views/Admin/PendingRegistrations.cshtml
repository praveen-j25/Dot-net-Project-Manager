@model TaskManagerMVC.ViewModels.PendingUserListVM
@{
    ViewData["Title"] = "Pending Registrations";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-person-check me-2 text-warning"></i>Pending Registrations
            </h1>
            <p class="text-muted mb-0">Review and approve new user registration requests</p>
        </div>
        <a href="@Url.Action("Users", "Admin")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Users
        </a>
    </div>

    <!-- Status Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="@Url.Action("PendingRegistrations")" 
                   class="btn @(string.IsNullOrEmpty(Model.StatusFilter) ? "btn-primary" : "btn-outline-primary")">
                    All (@Model.PendingUsers.Count)
                </a>
                <a href="@Url.Action("PendingRegistrations", new { status = "pending" })" 
                   class="btn @(Model.StatusFilter == "pending" ? "btn-warning" : "btn-outline-warning")">
                    Pending (@Model.PendingUsers.Count(u => u.Status == "pending"))
                </a>
                <a href="@Url.Action("PendingRegistrations", new { status = "approved" })" 
                   class="btn @(Model.StatusFilter == "approved" ? "btn-success" : "btn-outline-success")">
                    Approved (@Model.PendingUsers.Count(u => u.Status == "approved"))
                </a>
                <a href="@Url.Action("PendingRegistrations", new { status = "rejected" })" 
                   class="btn @(Model.StatusFilter == "rejected" ? "btn-danger" : "btn-outline-danger")">
                    Rejected (@Model.PendingUsers.Count(u => u.Status == "rejected"))
                </a>
            </div>
        </div>
    </div>

    <!-- Pending Users Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Applicant</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Department</th>
                            <th>Requested</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model.PendingUsers?.Any() == true)
                        {
                            @foreach(var user in Model.PendingUsers)
                            {
                                var statusBadge = user.Status switch
                                {
                                    "pending" => "bg-warning text-dark",
                                    "approved" => "bg-success",
                                    "rejected" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-md bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3">
                                                <span class="text-primary fw-medium">@user.Initials</span>
                                            </div>
                                            <div>
                                                <p class="mb-0 fw-medium">@user.FullName</p>
                                                <small class="text-muted">@user.JobTitle</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@user.Email</td>
                                    <td>@(user.Phone ?? "-")</td>
                                    <td>@(user.DepartmentName ?? "-")</td>
                                    <td>
                                        <small>@user.RequestedAt.ToString("MMM dd, yyyy")</small><br/>
                                        <small class="text-muted">@user.RequestedAt.ToString("hh:mm tt")</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @statusBadge">@user.Status.ToUpper()</span>
                                        @if(user.Status == "rejected" && !string.IsNullOrEmpty(user.RejectionReason))
                                        {
                                            <br/><small class="text-muted" title="@user.RejectionReason">
                                                <i class="bi bi-info-circle"></i> View reason
                                            </small>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if(user.Status == "pending")
                                        {
                                            <div class="btn-group">
                                                <a href="@Url.Action("ApproveRegistration", "Admin", new { id = user.Id })" 
                                                   class="btn btn-sm btn-success" title="Approve">
                                                    <i class="bi bi-check-circle me-1"></i>Approve
                                                </a>
                                                <button type="button" 
                                                        class="btn btn-sm btn-danger" 
                                                        title="Reject"
                                                        onclick="showRejectModal(@user.Id, '@user.FullName', '@user.Email')">
                                                    <i class="bi bi-x-circle me-1"></i>Reject
                                                </button>
                                            </div>
                                        }
                                        else if(user.Status == "approved")
                                        {
                                            <span class="text-success small">
                                                <i class="bi bi-check-circle-fill me-1"></i>Approved by @user.ReviewerName
                                            </span>
                                        }
                                        else if(user.Status == "rejected")
                                        {
                                            <span class="text-danger small">
                                                <i class="bi bi-x-circle-fill me-1"></i>Rejected by @user.ReviewerName
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                        <p class="mb-0">No registration requests found</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-x-circle me-2"></i>Reject Registration
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="RejectRegistration">
                <input type="hidden" id="rejectId" name="id" />
                <div class="modal-body">
                    <p>You are about to reject the registration request for:</p>
                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <p class="mb-1"><strong>Name:</strong> <span id="rejectName"></span></p>
                            <p class="mb-0"><strong>Email:</strong> <span id="rejectEmail"></span></p>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea class="form-control" 
                                  id="rejectionReason" 
                                  name="rejectionReason" 
                                  rows="3" 
                                  placeholder="Please provide a reason for rejection..."
                                  required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-circle me-2"></i>Reject Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showRejectModal(id, name, email) {
        document.getElementById('rejectId').value = id;
        document.getElementById('rejectName').textContent = name;
        document.getElementById('rejectEmail').textContent = email;
        document.getElementById('rejectionReason').value = '';
        
        const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
        modal.show();
    }
</script>
}

@section Styles {
<style>
    .avatar-md {
        width: 40px;
        height: 40px;
        font-size: 0.875rem;
    }
</style>
}
