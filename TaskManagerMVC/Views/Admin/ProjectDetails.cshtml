@model TaskManagerMVC.ViewModels.ProjectDetailsVM
@{
    ViewData["Title"] = Model.Name;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">@Model.Name</h1>
            <p class="text-muted mb-0">@Model.Code</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("EditProject", "Admin", new { id = Model.Id })" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-2"></i>Edit
            </a>
            <a href="@Url.Action("Projects", "Admin")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Project Info -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-3">Project Info</h6>
                    <div class="mb-3">
                        <small class="text-muted d-block">Status</small>
                        <span class="badge bg-@(Model.Status == "active" ? "success" : Model.Status == "completed" ? "primary" : "warning")">@Model.Status</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Priority</small>
                        <span class="badge bg-@(Model.Priority == "critical" ? "danger" : Model.Priority == "high" ? "warning" : "info")">@Model.Priority</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Department</small>
                        <strong>@(Model.DepartmentName ?? "N/A")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Manager</small>
                        <strong>@(Model.ManagerName ?? "Unassigned")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Timeline</small>
                        <strong>@(Model.StartDate?.ToString("MMM d, yyyy") ?? "TBD") - @(Model.EndDate?.ToString("MMM d, yyyy") ?? "TBD")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Budget</small>
                        <strong>₹@Model.Budget.ToString("N2")</strong>
                    </div>
                    <div>
                        <small class="text-muted d-block">Hours Logged</small>
                        <strong>@Model.TotalHoursLogged.ToString("N1")h</strong>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small mb-3">Description</h6>
                        <p class="mb-0">@Model.Description</p>
                    </div>
                </div>
            }
        </div>

        <!-- Stats & Tasks -->
        <div class="col-lg-8">
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center py-3">
                        <div class="h3 mb-1 text-primary">@Model.TotalTasks</div>
                        <small class="text-muted">Total Tasks</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center py-3">
                        <div class="h3 mb-1 text-success">@Model.CompletedTasks</div>
                        <small class="text-muted">Completed</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center py-3">
                        <div class="h3 mb-1 text-info">@Model.InProgressTasks</div>
                        <small class="text-muted">In Progress</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center py-3">
                        <div class="h3 mb-1 text-danger">@Model.OverdueTasks</div>
                        <small class="text-muted">Overdue</small>
                    </div>
                </div>
            </div>

            <!-- Progress -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <h6 class="mb-0">Overall Progress</h6>
                        <strong>@Model.ProgressPercent%</strong>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-primary" style="width: @Model.ProgressPercent%"></div>
                    </div>
                </div>
            </div>

            <!-- Tasks -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0"><i class="bi bi-list-task me-2"></i>Tasks (@Model.Tasks.Count)</h6>
                </div>
                <div class="card-body p-0">
                    @if (Model.Tasks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Title</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.Tasks)
                                    {
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("TaskDetails", "Admin", new { id = task.Id })">@task.Title</a>
                                            </td>
                                            <td><span class="badge bg-warning-subtle text-warning-emphasis">@task.PriorityName</span></td>
                                            <td><span class="badge bg-info-subtle text-info-emphasis">@task.StatusName</span></td>
                                            <td>@task.DueDate?.ToString("MMM d, yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">No tasks found for this project</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
