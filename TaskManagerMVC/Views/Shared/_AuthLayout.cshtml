<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        * { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        body {
            background: #0f172a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow-x: hidden;
        }
        .auth-wrapper {
            display: flex;
            width: 100%;
            max-width: 1100px;
            min-height: 600px;
            background: #fff;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 80px rgba(0,0,0,0.4);
            animation: fadeUp 0.6s ease-out;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(40px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* LEFT PANEL - Branding */
        .auth-brand-panel {
            width: 45%;
            background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 50%, #ec4899 100%);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
            color: white;
        }
        .auth-brand-panel::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            top: -200px; right: -200px;
        }
        .auth-brand-panel::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
            bottom: -100px; left: -100px;
        }
        .brand-logo {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 2.5rem; position: relative; z-index: 1;
        }
        .brand-logo-icon {
            width: 50px; height: 50px;
            background: rgba(255,255,255,0.2);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; backdrop-filter: blur(10px);
        }
        .brand-logo span { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px; }
        .brand-content { position: relative; z-index: 1; }
        .brand-content h1 { font-size: 2.2rem; font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
        .brand-content p { font-size: 1.05rem; opacity: 0.85; line-height: 1.7; margin-bottom: 2rem; }
        .brand-features { list-style: none; padding: 0; margin: 0; position: relative; z-index: 1; }
        .brand-features li {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 0; font-size: 0.95rem; opacity: 0.9;
        }
        .brand-features li i {
            width: 32px; height: 32px;
            background: rgba(255,255,255,0.15);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.9rem;
        }

        /* RIGHT PANEL - Form */
        .auth-form-panel {
            width: 55%;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #fff;
        }
        .auth-card {
            max-width: 440px;
            margin: 0 auto;
            width: 100%;
            box-shadow: none !important;
            border-radius: 0 !important;
        }
        .auth-card:hover { transform: none !important; box-shadow: none !important; }
        .auth-header {
            background: transparent !important;
            color: #0f172a !important;
            padding: 0 0 1.5rem 0 !important;
            text-align: left !important;
        }
        .auth-header i { display: none; }
        .auth-header h2 { font-size: 1.75rem; font-weight: 800; color: #0f172a; margin: 0; }
        .auth-header p { color: #64748b !important; opacity: 1 !important; font-size: 0.95rem; margin-top: 6px; }
        .auth-body { padding: 0 !important; }

        /* Form inputs */
        .auth-form-panel .form-control, .auth-form-panel .form-select {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.7rem 1rem;
            font-size: 0.9rem;
            background: #f8fafc;
            transition: all 0.3s;
        }
        .auth-form-panel .form-control:focus, .auth-form-panel .form-select:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 4px rgba(124,58,237,0.1);
            background: #fff;
        }
        .auth-form-panel .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: #334155;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }
        .auth-form-panel .btn-primary {
            background: linear-gradient(135deg, #7c3aed 0%, #2563eb 100%);
            border: none;
            border-radius: 12px;
            padding: 0.8rem;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
        }
        .auth-form-panel .btn-primary:hover {
            background: linear-gradient(135deg, #6d28d9 0%, #1d4ed8 100%);
            box-shadow: 0 8px 25px rgba(124,58,237,0.35);
            transform: translateY(-2px);
        }

        /* Role Selection Cards */
        .role-cards { display: flex; gap: 12px; margin-bottom: 1rem; }
        .role-card {
            flex: 1;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: #f8fafc;
        }
        .role-card:hover { border-color: #c4b5fd; background: #f5f3ff; }
        .role-card.active {
            border-color: #7c3aed;
            background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
            box-shadow: 0 4px 15px rgba(124,58,237,0.15);
        }
        .role-card i {
            font-size: 1.5rem; margin-bottom: 6px; display: block;
            color: #94a3b8;
        }
        .role-card.active i { color: #7c3aed; }
        .role-card .role-name { font-size: 0.82rem; font-weight: 700; color: #334155; }
        .role-card .role-desc { font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }

        /* Responsive */
        @@media (max-width: 768px) {
            .auth-wrapper { flex-direction: column; max-width: 500px; }
            .auth-brand-panel { width: 100%; padding: 2rem; }
            .auth-brand-panel h1 { font-size: 1.5rem; }
            .brand-features { display: none; }
            .auth-form-panel { width: 100%; padding: 2rem; }
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <!-- Left Branding Panel -->
        <div class="auth-brand-panel d-none d-md-flex">
            <div class="brand-logo">
                <div class="brand-logo-icon"><i class="bi bi-kanban-fill"></i></div>
                <span>TaskFlow Pro</span>
            </div>
            <div class="brand-content">
                <h1>Enterprise Project & Task Management</h1>
                <p>Streamline your team's workflow with professional task tracking, real-time collaboration, and advanced project management tools.</p>
            </div>
            <ul class="brand-features">
                <li><i class="bi bi-shield-check"></i> Role-based access control</li>
                <li><i class="bi bi-people-fill"></i> Team collaboration & assignment</li>
                <li><i class="bi bi-graph-up-arrow"></i> Performance analytics & reports</li>
                <li><i class="bi bi-paperclip"></i> File attachments & time tracking</li>
                <li><i class="bi bi-bell-fill"></i> Real-time notifications</li>
            </ul>
        </div>
        <!-- Right Form Panel -->
        <div class="auth-form-panel">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
