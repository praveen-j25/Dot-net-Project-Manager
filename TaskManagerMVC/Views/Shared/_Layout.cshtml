<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task Manager Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value 
               ?? User.Claims.FirstOrDefault(c => c.Type == "Role")?.Value 
               ?? "Employee";
        var isAdmin = role == "Administrator" || role == "Admin";
        var isManager = role == "Manager";
        var jobTitle = User.Claims.FirstOrDefault(c => c.Type == "JobTitle")?.Value ?? role;

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold d-flex align-items-center" href="@(isAdmin ? "/Admin" : isManager ? "/Manager" : "/Employee")">
                    <div class="bg-primary rounded p-2 me-2">
                        <i class="bi bi-kanban text-white"></i>
                    </div>
                    <span>Task Manager <span class="badge bg-primary ms-2 small">Pro</span></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (isAdmin)
                        {
                            <!-- Admin Navigation -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-list-task me-1"></i>Tasks
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="AssignTasks">
                                        <i class="bi bi-list-ul me-2"></i>All Tasks</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="AssignTask">
                                        <i class="bi bi-plus-circle me-2"></i>Assign New Task</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Tasks" asp-action="Index">
                                        <i class="bi bi-person-check me-2"></i>My Tasks</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-folder me-1"></i>Projects
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Projects">
                                        <i class="bi bi-folder2-open me-2"></i>All Projects</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateProject">
                                        <i class="bi bi-folder-plus me-2"></i>New Project</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-people me-1"></i>Team
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                        <i class="bi bi-people-fill me-2"></i>All Users</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateUser">
                                        <i class="bi bi-person-plus me-2"></i>Add Employee</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="PendingRegistrations">
                                        <i class="bi bi-person-check me-2"></i>Pending Registrations
                                        <span class="badge bg-warning text-dark ms-1" id="pendingCountBadge" style="display: none;">0</span>
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="TeamPerformance">
                                        <i class="bi bi-graph-up me-2"></i>Performance</a></li>
                                </ul>
                            </li>
                        }
                        else if (isManager)
                        {
                            <!-- Manager Navigation -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Manager" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-people me-1"></i>My Team
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="MyTeam">
                                        <i class="bi bi-people-fill me-2"></i>Team Members</a></li>
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="TeamPerformance">
                                        <i class="bi bi-graph-up me-2"></i>Performance</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-folder me-1"></i>My Projects
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="MyProjects">
                                        <i class="bi bi-folder2-open me-2"></i>All Projects</a></li>
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="MyProjects" asp-route-status="active">
                                        <i class="bi bi-play-circle me-2"></i>Active Projects</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-list-task me-1"></i>Tasks
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="TaskManagement">
                                        <i class="bi bi-list-ul me-2"></i>All Tasks</a></li>
                                    <li><a class="dropdown-item" asp-controller="Manager" asp-action="AssignTask">
                                        <i class="bi bi-plus-circle me-2"></i>Assign Task</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Tasks" asp-action="Index">
                                        <i class="bi bi-person-check me-2"></i>My Tasks</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- Employee Navigation -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="MyTasks">
                                    <i class="bi bi-list-task me-1"></i>My Tasks
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="MyTimeLogs">
                                    <i class="bi bi-clock-history me-1"></i>Time Logs
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right Side -->
                    <ul class="navbar-nav">
                        <!-- Notifications -->
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link position-relative" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-bell fs-5"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge" style="display: none;">
                                    0
                                </span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end notification-dropdown" style="width: 320px;">
                                <h6 class="dropdown-header">Notifications</h6>
                                <div class="notification-list" style="max-height: 300px; overflow-y: auto;">
                                    <div class="text-center py-4 text-muted">
                                        <i class="bi bi-bell-slash fs-3 d-block mb-2"></i>
                                        <small>No new notifications</small>
                                    </div>
                                </div>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item text-center small" href="@(isAdmin ? Url.Action("Notifications", "Admin") : isManager ? Url.Action("Notifications", "Manager") : Url.Action("Notifications", "Employee"))">
                                    View All Notifications
                                </a>
                            </div>
                        </li>

                        <!-- User Profile Menu -->
                        <li class="nav-item dropdown">
                            <a class="nav-link d-flex align-items-center px-2" href="#" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="position-relative">
                                    @{
                                        var profileImage = User.Claims.FirstOrDefault(c => c.Type == "ProfileImage")?.Value;
                                        var userName = User.Identity?.Name ?? "User";
                                        var nameParts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                        string initials;
                                        
                                        if (nameParts.Length > 1 && nameParts[0].Length > 0 && nameParts[1].Length > 0)
                                        {
                                            initials = nameParts[0][0].ToString().ToUpper() + nameParts[1][0].ToString().ToUpper();
                                        }
                                        else if (userName.Length >= 2)
                                        {
                                            initials = userName.Substring(0, 2).ToUpper();
                                        }
                                        else if (userName.Length == 1)
                                        {
                                            initials = userName.ToUpper();
                                        }
                                        else
                                        {
                                            initials = "US";
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(profileImage))
                                    {
                                        <img src="@profileImage" alt="@userName" 
                                             class="rounded-circle flex-shrink-0" 
                                             style="width: 36px; height: 36px; min-width: 36px; object-fit: cover; border: 2px solid rgba(255,255,255,0.3);" 
                                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                        
                                        <div class="rounded-circle align-items-center justify-content-center flex-shrink-0" 
                                             style="width: 36px; height: 36px; min-width: 36px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: none;">
                                            <span class="text-white fw-bold" style="font-size: 0.8rem;">
                                                @initials
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                                             style="width: 36px; height: 36px; min-width: 36px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                            <span class="text-white fw-bold" style="font-size: 0.8rem;">
                                                @initials
                                            </span>
                                        </div>
                                    }
                                    <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-dark rounded-circle" 
                                          style="width: 9px; height: 9px;"></span>
                                </div>
                                <i class="bi bi-chevron-down ms-2 text-white" style="font-size: 0.7rem;"></i>
                            </a>
                            
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width: 200px; border-radius: 8px;">
                                <li class="px-3 py-2">
                                    <div class="fw-bold text-dark small">@User.Identity?.Name</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@role</div>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li>
                                    <a class="dropdown-item py-2" href="@(isAdmin ? Url.Action("Profile", "Admin") : isManager ? Url.Action("Profile", "Manager") : Url.Action("Profile", "Employee"))">
                                        <i class="bi bi-person-circle me-2"></i>Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2" href="@(isAdmin ? Url.Action("Settings", "Admin") : isManager ? Url.Action("Settings", "Manager") : Url.Action("Settings", "Employee"))">
                                        <i class="bi bi-gear me-2"></i>Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li class="px-2 pb-2">
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="btn btn-danger btn-sm w-100">
                                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <main class="@(User.Identity?.IsAuthenticated == true ? "" : "")">
        @RenderBody()
    </main>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <footer class="footer mt-auto py-3 bg-light border-top">
            <div class="container-fluid px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">&copy; @DateTime.Now.Year Task Manager Pro. Enterprise Edition.</span>
                    <span class="text-muted small">Version 2.0</span>
                </div>
            </div>
        </footer>
    }

    @await RenderSectionAsync("Modals", required: false)

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notification.js" asp-append-version="true"></script>

    <script>
        // Global Toast Notification Function
        function showToast(message, type = 'success') {
            // Remove existing toasts
            $('.global-toast').remove();
            
            // Determine styling based on type
            var bgClass, icon, title;
            switch(type) {
                case 'success':
                    bgClass = 'bg-success';
                    icon = 'bi-check-circle-fill';
                    title = 'Success!';
                    break;
                case 'error':
                    bgClass = 'bg-danger';
                    icon = 'bi-exclamation-circle-fill';
                    title = 'Error!';
                    break;
                case 'warning':
                    bgClass = 'bg-warning';
                    icon = 'bi-exclamation-triangle-fill';
                    title = 'Warning!';
                    break;
                case 'info':
                    bgClass = 'bg-info';
                    icon = 'bi-info-circle-fill';
                    title = 'Info';
                    break;
                default:
                    bgClass = 'bg-primary';
                    icon = 'bi-bell-fill';
                    title = 'Notification';
            }
            
            // Create toast HTML
            var toast = $('<div class="global-toast position-fixed top-0 end-0 m-3 p-3 ' + bgClass + ' text-white rounded shadow-lg" style="z-index: 9999; min-width: 300px; animation: slideInRight 0.3s ease-out;">' +
                '<div class="d-flex align-items-center">' +
                    '<i class="bi ' + icon + ' fs-4 me-3"></i>' +
                    '<div class="flex-grow-1">' +
                        '<div class="fw-bold">' + title + '</div>' +
                        '<div class="small">' + message + '</div>' +
                    '</div>' +
                    '<button type="button" class="btn-close btn-close-white ms-2" aria-label="Close"></button>' +
                '</div>' +
            '</div>');
            
            // Add to body
            $('body').append(toast);
            
            // Close button handler
            toast.find('.btn-close').on('click', function() {
                toast.fadeOut(300, function() {
                    $(this).remove();
                });
            });
            
            // Auto-remove after 5 seconds
            setTimeout(function() {
                toast.fadeOut(300, function() {
                    $(this).remove();
                });
            }, 5000);
        }

        // Add CSS animation
        if (!document.getElementById('toast-animations')) {
            var style = document.createElement('style');
            style.id = 'toast-animations';
            style.textContent = '@@keyframes slideInRight { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }';
            document.head.appendChild(style);
        }

        // Check for TempData messages on page load
        $(document).ready(function() {
            @if (TempData["Success"] != null)
            {
                <text>showToast(@Json.Serialize(TempData["Success"]), 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                <text>showToast(@Json.Serialize(TempData["Error"]), 'error');</text>
            }
            @if (TempData["Warning"] != null)
            {
                <text>showToast(@Json.Serialize(TempData["Warning"]), 'warning');</text>
            }
            @if (TempData["Info"] != null)
            {
                <text>showToast(@Json.Serialize(TempData["Info"]), 'info');</text>
            }
        });
    </script>

    @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Administrator")))
    {
        <script>
            // Load pending registration count
            async function loadPendingCount() {
                try {
                    const response = await fetch('/Admin/GetPendingRegistrationCount');
                    const data = await response.json();
                    
                    if (data.count > 0) {
                        const badge = document.getElementById('pendingCountBadge');
                        if (badge) {
                            badge.textContent = data.count;
                            badge.style.display = 'inline-block';
                        }
                    }
                } catch (error) {
                    console.error('Error loading pending count:', error);
                }
            }
            
            // Load on page load
            document.addEventListener('DOMContentLoaded', loadPendingCount);
            
            // Refresh every 30 seconds
            setInterval(loadPendingCount, 30000);
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
