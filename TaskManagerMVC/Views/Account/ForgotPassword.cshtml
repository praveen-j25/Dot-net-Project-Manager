@model ForgotPasswordVM
@{ ViewData["Title"] = "Forgot Password"; Layout = "_AuthLayout"; }

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="bi bi-key text-primary" style="font-size: 3rem;"></i>
        <h2 class="mt-3 fw-bold">Forgot Password?</h2>
        <p class="text-muted">Enter your email to reset</p>
    </div>

    <form asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        
        <div class="mb-4">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter email">
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
            <i class="bi bi-send me-2"></i>Send Reset Link
        </button>

        <p class="text-center mb-0">
            <a asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </p>
    </form>
</div>
