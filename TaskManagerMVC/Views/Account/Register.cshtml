@model RegisterVM
@{ ViewData["Title"] = "Create Account"; Layout = "_AuthLayout"; }

<div class="auth-card card">
    <div class="auth-header">
        <h2>Create your account</h2>
        <p class="mb-0">Join your team and start managing projects</p>
    </div>
    <div class="auth-body">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2 px-3" style="border-radius:10px; font-size:0.88rem;">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:0.88rem; border-radius:10px;"></div>

            <!-- Role Selection - REMOVED FOR SECURITY -->
            <!-- Public registration is ALWAYS Employee role. Only admins can create Admin/Manager accounts. -->
            <input type="hidden" asp-for="RoleId" value="3" id="roleInput" />
            
            <div class="alert alert-info py-2 px-3 mb-3" style="border-radius:10px; font-size:0.85rem; background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.2); color: #0369a1;">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Note:</strong> New registrations are created as <strong>Employee</strong> accounts. Contact your administrator for role upgrades.
            </div>

            <!-- Name Row -->
            <div class="row">
                <div class="col-6 mb-3">
                    <label asp-for="FirstName" class="form-label">
                        <i class="bi bi-person me-1"></i>First Name
                    </label>
                    <input asp-for="FirstName" class="form-control" placeholder="John">
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-6 mb-3">
                    <label asp-for="LastName" class="form-label">
                        <i class="bi bi-person me-1"></i>Last Name
                    </label>
                    <input asp-for="LastName" class="form-control" placeholder="Doe">
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label">
                    <i class="bi bi-envelope me-1"></i>Work Email
                </label>
                <input asp-for="Email" class="form-control" placeholder="john.doe@company.com" autocomplete="email">
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Phone & Department Row -->
            <div class="row">
                <div class="col-6 mb-3">
                    <label asp-for="Phone" class="form-label">
                        <i class="bi bi-telephone me-1"></i>Phone
                    </label>
                    <input asp-for="Phone" class="form-control" placeholder="+91 98765 43210">
                </div>
                <div class="col-6 mb-3">
                    <label asp-for="DepartmentId" class="form-label">
                        <i class="bi bi-building me-1"></i>Department
                    </label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select">
                        <option value="">Select...</option>
                    </select>
                </div>
            </div>

            <!-- Job Title -->
            <div class="mb-3">
                <label asp-for="JobTitle" class="form-label">
                    <i class="bi bi-briefcase me-1"></i>Job Title
                </label>
                <input asp-for="JobTitle" class="form-control" placeholder="e.g. Software Engineer, Project Manager">
            </div>

            <!-- Password -->
            <div class="row">
                <div class="col-6 mb-3">
                    <label asp-for="Password" class="form-label">
                        <i class="bi bi-lock me-1"></i>Password
                    </label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Min 6 chars" id="regPassword">
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regPassword', this)" style="border-radius: 0 12px 12px 0; border: 2px solid #e2e8f0; border-left: 0;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-6 mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">
                        <i class="bi bi-lock-fill me-1"></i>Confirm
                    </label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter" id="regConfirmPassword">
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regConfirmPassword', this)" style="border-radius: 0 12px 12px 0; border: 2px solid #e2e8f0; border-left: 0;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3 mt-2">
                <i class="bi bi-person-plus me-2"></i>Create Account
            </button>

            <div class="text-center">
                <span class="text-muted small">Already have an account?</span>
                <a asp-action="Login" class="fw-bold text-decoration-none ms-1 small" style="color:#7c3aed;">Sign In</a>
            </div>
        </form>

        <div class="mt-3 pt-3" style="border-top: 1px solid #e2e8f0;">
            <p class="text-center text-muted" style="font-size: 0.78rem;">
                <i class="bi bi-shield-fill-check me-1"></i>
                Your data is protected with enterprise-grade security
            </p>
        </div>
    </div>
</div>

<script>
function togglePassword(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
}
</script>
