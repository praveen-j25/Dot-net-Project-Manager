@model ResetPasswordVM
@{ ViewData["Title"] = "Reset Password"; Layout = "_AuthLayout"; }

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
        <h2 class="mt-3 fw-bold">Reset Password</h2>
    </div>

    <form asp-action="ResetPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input asp-for="Token" type="hidden">
        
        <div class="mb-3">
            <label asp-for="Password" class="form-label">New Password</label>
            <input asp-for="Password" type="password" class="form-control form-control-lg">
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg">
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100">
            <i class="bi bi-check-lg me-2"></i>Reset Password
        </button>
    </form>
</div>
