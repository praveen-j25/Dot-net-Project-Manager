@model DashboardVM
@{ ViewData["Title"] = "Dashboard"; }

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
            <p class="text-muted mb-0">Welcome back! Here's your task overview.</p>
        </div>
        <a asp-controller="Tasks" asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-2"></i>New Task
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="stat-card primary animate-in">
                <i class="bi bi-list-task"></i>
                <h2>@Model.TotalTasks</h2>
                <p>Total Tasks</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card warning animate-in" style="animation-delay: 0.1s;">
                <i class="bi bi-hourglass-split"></i>
                <h2>@Model.PendingTasks</h2>
                <p>Pending</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card info animate-in" style="animation-delay: 0.2s;">
                <i class="bi bi-play-circle"></i>
                <h2>@Model.InProgressTasks</h2>
                <p>In Progress</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card success animate-in" style="animation-delay: 0.3s;">
                <i class="bi bi-check-circle"></i>
                <h2>@Model.CompletedTasks</h2>
                <p>Completed</p>
            </div>
        </div>
    </div>

    <!-- Task Lists -->
    <div class="row g-4">
        <!-- Overdue Tasks -->
        <div class="col-lg-6">
            <div class="card h-100 animate-in" style="animation-delay: 0.4s;">
                <div class="card-header" style="background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);">
                    <i class="bi bi-exclamation-triangle me-2"></i>Overdue Tasks
                    @if (Model.OverdueTasks?.Any() == true)
                    {
                        <span class="badge bg-white text-danger float-end">@Model.OverdueTasks.Count()</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.OverdueTasks?.Any() == true)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var task in Model.OverdueTasks)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3 task-overdue">
                                    <div>
                                        <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="fw-semibold text-decoration-none">
                                            @task.Title
                                        </a>
                                        <small class="d-block text-muted">@task.CategoryName</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-high">Overdue</span>
                                        <small class="d-block text-danger mt-1">
                                            <i class="bi bi-calendar-x me-1"></i>@task.DueDate?.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="empty-state py-5">
                            <i class="bi bi-emoji-smile d-block"></i>
                            <p class="mb-0">No overdue tasks. Great job!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Tasks -->
        <div class="col-lg-6">
            <div class="card h-100 animate-in" style="animation-delay: 0.5s;">
                <div class="card-header">
                    <i class="bi bi-clock-history me-2"></i>Recent Tasks
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentTasks?.Any() == true)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var task in Model.RecentTasks)
                            {
                                var statusClass = task.StatusName?.ToLower().Replace(" ", "") ?? "pending";
                                <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                                    <div>
                                        <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="fw-semibold text-decoration-none">
                                            @task.Title
                                        </a>
                                        <small class="d-block text-muted">@task.CategoryName</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-@statusClass">@task.StatusName</span>
                                        <small class="d-block text-muted mt-1">
                                            <i class="bi bi-calendar me-1"></i>@task.DueDate?.ToString("MMM dd")
                                        </small>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="empty-state py-5">
                            <i class="bi bi-inbox d-block"></i>
                            <p class="mb-2">No tasks yet</p>
                            <a asp-controller="Tasks" asp-action="Create" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus me-1"></i>Create your first task
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card animate-in" style="animation-delay: 0.6s;">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a asp-controller="Tasks" asp-action="Index" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-list-ul me-2"></i>View All Tasks
                        </a>
                        <a asp-controller="Tasks" asp-action="Create" class="btn btn-outline-success btn-lg">
                            <i class="bi bi-plus-circle me-2"></i>Add New Task
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
